{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and role information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["client", "admin", "super_admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "LocalizedString": {
      "title": "LocalizedString",
      "description": "String translated into multiple languages",
      "type": "object",
      "properties": {
        "en": { "type": "string" },
        "zh": { "type": "string" },
        "ms": { "type": "string" }
      },
      "required": ["en", "zh", "ms"]
    },
    "Product": {
      "title": "Product",
      "description": "Snack product details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "price": { "type": "number" },
        "image": { "type": "string", "format": "uri" },
        "weight": { "type": "string" },
        "isHalal": { "type": "boolean" },
        "stockStatus": { "type": "string", "enum": ["in_stock", "out_of_stock"] },
        "name": { "$ref": "#/entities/LocalizedString" },
        "description": { "$ref": "#/entities/LocalizedString" },
        "ingredients": { "$ref": "#/entities/LocalizedString" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "price", "image", "weight", "isHalal", "stockStatus", "name", "description", "ingredients", "createdAt"]
    },
    "OrderItem": {
      "title": "OrderItem",
      "description": "An item within an order",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "quantity": { "type": "number" },
        "priceAtPurchase": { "type": "number" },
        "name": { "$ref": "#/entities/LocalizedString" }
      },
      "required": ["productId", "quantity", "priceAtPurchase", "name"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "userId": { "type": "string" },
        "items": {
          "type": "array",
          "items": { "$ref": "#/entities/OrderItem" }
        },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["orderId", "userId", "items", "totalAmount", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Snack products inventory"
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Customer orders"
    }
  }
}
